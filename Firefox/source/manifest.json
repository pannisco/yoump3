{
  "manifest_version": 2,
  "name": "YouMP3",
  "version": "1.1.5",
  "description": "Download music directly from the browser.",
  
  "browser_action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  
  "permissions": [
    "*://*.youtube.com/*", 
    "*://music.youtube.com/*"
  ],
  
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["popup.js"],  
      "css": ["styles.css"], 
      "run_at": "document_idle" 
    }
  ]
}